{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "experimentalServices": {
    "frontend": {
      "entrypoint": "frontend",
      "framework": "nextjs",
      "routePrefix": "/"
    },
    "backend": {
      "entrypoint": "backend",
      "framework": "fastapi",
      "routePrefix": "/api",
      "maxDuration": 300
    }
  },
  "crons": [
    {
      "path": "/api/worker/poll-once?secret=censor-demo-2026",
      "schedule": "* * * * *"
    }
  ]
}
