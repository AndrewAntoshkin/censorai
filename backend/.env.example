DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/censorai
DATABASE_URL_SYNC=postgresql+psycopg2://postgres:postgres@localhost:5432/censorai

# docker compose up -d postgres redis
# AUTH_REQUIRED=true — каждый пользователь видит только свои проекты (+ общий демо без owner)
AUTH_REQUIRED=true
AUTH_SECRET=change-me-to-a-long-random-string
SUPER_ADMIN_EMAIL=andrew.antoshkin@gmail.com
FRAMECHECK_REGISTRATION_CODE=FRAMECHECK2026

# On Vercel: POSTGRES_URL is auto-set from Vercel Postgres / Neon.
# On Vercel: BLOB_READ_WRITE_TOKEN is auto-set from Vercel Blob.

REDIS_URL=redis://localhost:6379/0
# Background analysis poll (arq worker). Requires Redis.
ANALYSIS_WORKER_POLL_SECONDS=30
ANALYSIS_JOB_MAX_ATTEMPTS=5
ANALYSIS_STALE_JOB_HOURS=6
# ffmpeg scene hints in prompt (stage 4 pilot)
# ANALYSIS_CASCADE_ENABLED=true

# S3-compatible storage (MinIO: docker compose up -d minio)
# S3_ENDPOINT_URL=http://localhost:9000
# S3_ACCESS_KEY=minioadmin
# S3_SECRET_KEY=minioadmin
# S3_BUCKET=censorai
# S3_REGION=auto
# S3_PRESIGN_TTL_SECONDS=7200

# Production analysis uses Replicate only (VIDEO_PROVIDER=gemini is ignored).
VIDEO_PROVIDER=replicate

# Local dev manual worker tick: GET /api/worker/poll-once?secret=<this>
WORKER_DEV_POLL_SECRET=dev-poll-local

MINIO_ENDPOINT=localhost:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET=censorai

GEMINI_API_KEY=your-gemini-api-key-here
GEMINI_MODEL=gemini-2.5-pro-preview-05-06

REPLICATE_API_TOKEN=your-replicate-api-token-here
REPLICATE_MODEL=google/gemini-3.5-flash

# Public URL for Replicate to fetch large videos (>100 MB). On Vercel auto from VERCEL_URL.
# PUBLIC_API_BASE_URL=https://censorai.vercel.app

UPLOAD_MAX_SIZE_MB=500
UPLOAD_DIR=./uploads
# Above this size, videos go to Blob or signed URL (not base64). Keep low (4) for episodes.
INLINE_VIDEO_MAX_MB=4

# Local dev for files > INLINE_VIDEO_MAX_MB: set Vercel Blob token (public URLs for Replicate)
# BLOB_READ_WRITE_TOKEN=vercel_blob_rw_...

GEMINI_MAX_CONCURRENT=3

# Legal registries (255-ФЗ / 114-ФЗ): bundled JSON in app/data/registries/.
# Refresh: python scripts/sync_legal_registries.py

# On Vercel, delete Blob video after successful analysis (default true).
# DELETE_BLOB_AFTER_ANALYSIS=true
