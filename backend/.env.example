DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/censorai
DATABASE_URL_SYNC=postgresql+psycopg2://postgres:postgres@localhost:5432/censorai

# On Vercel: POSTGRES_URL is auto-set from Vercel Postgres / Neon.
# On Vercel: BLOB_READ_WRITE_TOKEN is auto-set from Vercel Blob.

REDIS_URL=redis://localhost:6379/0

MINIO_ENDPOINT=localhost:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET=censorai

GEMINI_API_KEY=your-gemini-api-key-here
GEMINI_MODEL=gemini-2.5-pro-preview-05-06

REPLICATE_API_TOKEN=your-replicate-api-token-here
REPLICATE_MODEL=google/gemini-3.5-flash

# Public URL for Replicate to fetch large videos (>100 MB). On Vercel auto from VERCEL_URL.
# PUBLIC_API_BASE_URL=https://censorai.vercel.app

UPLOAD_MAX_SIZE_MB=500
UPLOAD_DIR=./uploads
# Above this size, videos go to Blob or signed URL (not base64). Keep low (4) for episodes.
INLINE_VIDEO_MAX_MB=4

# Local dev for files > INLINE_VIDEO_MAX_MB: set Vercel Blob token (public URLs for Replicate)
# BLOB_READ_WRITE_TOKEN=vercel_blob_rw_...

GEMINI_MAX_CONCURRENT=3

# Legal registries (255-ФЗ / 114-ФЗ): bundled JSON in app/data/registries/.
# Refresh: python scripts/sync_legal_registries.py
